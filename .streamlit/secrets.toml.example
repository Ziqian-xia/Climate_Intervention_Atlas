# Streamlit Secrets Template
# ============================================================================
# FOR STREAMLIT CLOUD DEPLOYMENT
# ============================================================================
# 1. Copy this file's content
# 2. In Streamlit Cloud, go to: App Settings → Secrets
# 3. Paste and fill in your actual API keys
# 4. DO NOT commit secrets.toml to Git!
# ============================================================================

# =============================================================================
# PHASE 1: LLM Provider (Query Generation)
# =============================================================================
[llm]
provider = "bedrock"  # Options: "anthropic", "bedrock", "dummy"

# Option A: Anthropic Direct API
anthropic_api_key = "your_anthropic_api_key_here"

# Option B: AWS Bedrock (Recommended)
aws_region = "us-east-1"
aws_model_id = "us.anthropic.claude-sonnet-4-6"
aws_access_key_id = "your_aws_access_key_id"
aws_secret_access_key = "your_aws_secret_access_key"

# =============================================================================
# PHASE 2: Search APIs (Literature Search)
# =============================================================================
[search]

# OpenAlex (Free, Recommended)
openalex_api_key = ""  # Optional, leave empty for free tier
openalex_mailto = "your@email.com"  # Required

# PubMed (Free with API key from NCBI)
pubmed_api_key = "your_pubmed_api_key"
pubmed_email = "your@email.com"

# Scopus (Requires institutional access)
scopus_api_key = "your_scopus_api_key"
scopus_insttoken = "your_institutional_token"  # Optional

# =============================================================================
# PHASE 3: Abstract Screening (LLMscreen uses OpenAI)
# =============================================================================
[screening]
openai_api_key = "your_openai_api_key"  # Required for Phase 3

# =============================================================================
# PHASE 4: Full-Text Retrieval APIs
# =============================================================================
[fulltext]

# Wiley TDM API (Request at https://onlinelibrary.wiley.com/library-info/resources/text-and-datamining)
wiley_tdm_client_token = "your_wiley_tdm_token"

# Elsevier API (Institutional access)
elsevier_api_key = "your_elsevier_api_key"
elsevier_inst_token = ""  # Optional

# =============================================================================
# OPTIONAL: Application Settings
# =============================================================================
[app]
debug = false
log_level = "INFO"
