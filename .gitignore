.playwright/

# =============================================================================
# Documentation (keep templates, ignore generated)
# =============================================================================
# Keep markdown docs but ignore large test reports
*REPORT*.md
!FINAL_TEST_REPORT.md
variation_test_summary_*.json
test_report_*.json

# =============================================================================
# Data Files (Large or Sensitive)
# =============================================================================
# Large CSV files (keep samples, ignore big exports)
*.csv
!sample_*.csv
!*example*.csv
!test_data/*.csv

# Large JSON files
works_full.jsonl
*_full.jsonl

# Database files
*.db
*.sqlite
*.sqlite3

# Compressed archives
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# PDF files (copyrighted)
*.pdf
!docs/**/*.pdf

