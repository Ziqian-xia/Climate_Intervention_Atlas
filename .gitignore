# =============================================================================
# Test & Development Files
# =============================================================================
# Test scripts (keep template, ignore outputs)
run_*_test.py
!run_two_topics_test.sh
test_*.py
*_test.py
comprehensive_test.py
quick_test.py

# Test data outputs
test_data/**/output*/
