# Auto-SLR Pipeline Environment Variables

# ===== Phase 1: LLM Provider Configuration =====

# LLM Provider Selection (anthropic | bedrock | dummy)
LLM_PROVIDER=bedrock

# Anthropic Direct API (if using provider=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS Bedrock Configuration (if using provider=bedrock)
# Note: Use cross-region inference profiles (us.anthropic.*) for on-demand access
# Latest models: claude-sonnet-4-6, claude-opus-4-6-v1
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ===== Phase 2: Search API Configuration =====

# OpenAlex API (optional but recommended)
OPENALEX_API_KEY=your_openalex_api_key
OPENALEX_MAILTO=your_email@domain.com

# PubMed/NCBI E-utilities API (optional but recommended)
PUBMED_API_KEY=your_ncbi_api_key
PUBMED_EMAIL=your_email@domain.com

# Scopus/Elsevier API (required for Scopus searches)
ELSEVIER_API_KEY=your_elsevier_api_key
ELSEVIER_INST_TOKEN=your_institutional_token

# ===== General Settings =====

# Optional: Set to 1 to enable debug logging
DEBUG=0
