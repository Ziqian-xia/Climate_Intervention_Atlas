# ============================================================================
# Climate Intervention Atlas - Environment Variables Template
# ============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys below
# 3. NEVER commit .env to git (it's in .gitignore)
# 4. See ENV_SETUP_GUIDE.md for detailed instructions
#
# ============================================================================

# =============================================================================
# PHASE 1 & 3: LLM PROVIDER (Query Generation + Screening)
# =============================================================================

# Choose your provider: anthropic | bedrock | dummy
LLM_PROVIDER=bedrock

# -----------------------------------------------------------------------------
# Option 1: Anthropic Direct API
# Get key at: https://console.anthropic.com/
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# -----------------------------------------------------------------------------
# Option 2: AWS Bedrock (Recommended for enterprise)
# Get credentials at: https://console.aws.amazon.com/
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Bedrock Model ID - Latest: Claude Sonnet 4.6
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Alternative model IDs:
# us.anthropic.claude-sonnet-4-20250514-v1:0  (Sonnet 4)
# us.anthropic.claude-opus-4-6                (Opus 4.6 - most capable)
# us.anthropic.claude-haiku-4-5               (Haiku 4.5 - fastest)

# -----------------------------------------------------------------------------
# Option 3: Dummy Provider (Testing without API calls)
# No credentials needed - set LLM_PROVIDER=dummy
# -----------------------------------------------------------------------------


# =============================================================================
# PHASE 2: SEARCH DATABASES (Literature Search)
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAlex (Free, Recommended)
# Get key at: https://openalex.org/ (optional but recommended)
# -----------------------------------------------------------------------------
OPENALEX_API_KEY=your_openalex_api_key
OPENALEX_MAILTO=your_email@domain.com

# -----------------------------------------------------------------------------
# PubMed / NCBI E-utilities (Free)
# Get key at: https://www.ncbi.nlm.nih.gov/account/ (optional)
# API key increases rate limit from 3 to 10 requests/second
# -----------------------------------------------------------------------------
PUBMED_API_KEY=your_ncbi_api_key
PUBMED_EMAIL=your_email@domain.com

# -----------------------------------------------------------------------------
# Scopus / Elsevier (Requires Subscription)
# Get key at: https://dev.elsevier.com/
# -----------------------------------------------------------------------------
ELSEVIER_API_KEY=your_elsevier_api_key
ELSEVIER_INST_TOKEN=your_institutional_token

# Alternative variable names (also supported):
SCOPUS_API_KEY=your_scopus_api_key
SCOPUS_INST_TOKEN=your_scopus_inst_token


# =============================================================================
# PHASE 4: FULL-TEXT RETRIEVAL (PDF/XML Download)
# =============================================================================

# -----------------------------------------------------------------------------
# Wiley TDM API (for Wiley journals)
# Get token at: https://onlinelibrary.wiley.com/library-info/resources/text-and-datamining
# -----------------------------------------------------------------------------
WILEY_TDM_CLIENT_TOKEN=your_wiley_tdm_token

# -----------------------------------------------------------------------------
# Elsevier Full-Text (uses same credentials as Scopus above)
# -----------------------------------------------------------------------------
# ELSEVIER_API_KEY=your_elsevier_api_key
# ELSEVIER_INST_TOKEN=your_institutional_token


# =============================================================================
# CLIMATE DATA (for exTweather-hazard pipeline)
# =============================================================================

# -----------------------------------------------------------------------------
# Copernicus Climate Data Store (ERA5, GloFAS)
# Get credentials at: https://cds.climate.copernicus.eu/
# Note: Also supports .cdsapirc file in home directory
# -----------------------------------------------------------------------------
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=your_cds_api_key


# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# -----------------------------------------------------------------------------
# Proxy Configuration (if behind corporate firewall)
# -----------------------------------------------------------------------------
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Debug mode (0 = off, 1 = on)
DEBUG=0

# Verbose API logging
# VERBOSE_API_LOGS=0

# Log file location
# LOG_FILE=app.log


# =============================================================================
# SECURITY REMINDERS
# =============================================================================
#
# ⚠️  NEVER commit .env to git!
# ⚠️  NEVER share API keys publicly!
# ⚠️  Rotate keys every 90 days
# ⚠️  Use separate keys for dev/prod
# ⚠️  Monitor API usage regularly
# ⚠️  Revoke compromised keys immediately
#
# =============================================================================
